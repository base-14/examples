# Strong password required by SQL Server policy: 8+ chars, mixed case, digit, symbol.
# The default below is for LOCAL DEV ONLY. Rotate before any other use.
MSSQL_SA_PASSWORD=Str0ng!P@ssw0rd-2026

# Read-only monitoring login the collector connects as.
# Created by the init-monitor-user service from this password on first `up`.
SQLSERVER_USER=otel_monitor
SQLSERVER_PASSWORD=Otel-M0nitor!2026

# Resource attribute context.
ENVIRONMENT=development
SERVICE_NAME=sqlserver-telemetry

# Scout OTLP/HTTP endpoint. Set to your tenant URL.
# Without this, the collector still works but the otlphttp/b14 exporter will fail
# to send. The debug exporter prints metrics to stdout regardless.
OTEL_EXPORTER_OTLP_ENDPOINT=https://<your-tenant>.base14.io
