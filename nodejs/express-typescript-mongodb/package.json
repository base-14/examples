{
  "name": "express-typescript-mongodb-otel",
  "version": "1.0.0",
  "type": "module",
  "description": "Express.js + TypeScript + MongoDB + OpenTelemetry example",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --import ./dist/instrumentation.js dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "build-lint": "npm run build && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "build-lint-test": "npm run build && npm run lint && npm run test",
    "build-lint-test-audit": "npm run build && npm run lint && npm run test && npm audit",
    "check": "npm run build && npm run lint && npm run test"
  },
  "keywords": [
    "express",
    "typescript",
    "mongodb",
    "opentelemetry",
    "observability"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-express": "^0.67.0",
    "@opentelemetry/instrumentation-http": "^0.219.0",
    "@opentelemetry/instrumentation-ioredis": "^0.67.0",
    "@opentelemetry/instrumentation-mongodb": "^0.72.0",
    "@opentelemetry/instrumentation-mongoose": "^0.65.0",
    "@opentelemetry/instrumentation-winston": "^0.63.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dompurify": "^3.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "isomorphic-dompurify": "^3.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.0.0",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@grpc/grpc-js": ">=1.14.4",
    "@grpc/proto-loader": {
      "protobufjs": "^7.5.6"
    },
    "qs": "^6.14.2",
    "tmp": ">=0.2.6",
    "diff": ">=8.0.3",
    "ioredis": "^5.10.1",
    "flatted": ">=3.4.2",
    "follow-redirects": "^1.16.0",
    "ip-address": ">=10.1.1",
    "undici": ">=7.24.0",
    "uuid": ">=14.0.0",
    "yauzl": ">=3.2.1",
    "ws": ">=8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "ioredis-mock": "^8.13.1",
    "mongodb-memory-server": "^11.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
