{
  "name": "express5-postgres",
  "version": "1.1.0",
  "description": "Express 5 + PostgreSQL + OpenTelemetry Example",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/jobs/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "bash scripts/test-api.sh",
    "test:websocket": "node scripts/test-websocket.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "build:lint": "npm run build && npm run lint"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation-socket.io": "^0.65.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@grpc/grpc-js": ">=1.14.4",
    "@grpc/proto-loader": {
      "protobufjs": "^7.5.6"
    },
    "qs": "^6.14.2",
    "esbuild": "^0.27.2",
    "uuid": ">=14.0.0",
    "ws": ">=8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
