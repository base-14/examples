{
  "name": "angular-items-api",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Express + Postgres API for the Angular full-stack OpenTelemetry example",
  "scripts": {
    "build": "tsc",
    "start": "node -r ./dist/instrumentation.js ./dist/server.js",
    "dev": "tsc && npm start"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-logs-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-proto": "0.220.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-logs": "0.219.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "cors": "^2.8.5",
    "express": "5.2.1",
    "pg": "8.22.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.9.0"
  }
}
