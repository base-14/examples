{
  "name": "nextjs-api-mongodb",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "worker": "tsx --import ./src/jobs/instrumentation.ts src/jobs/worker.ts",
    "build:worker": "esbuild src/jobs/instrumentation.ts src/jobs/worker.ts --bundle --platform=node --target=node24 --format=esm --outdir=dist --external:bullmq --external:ioredis --external:pino --external:@opentelemetry/*",
    "test": "vitest run",
    "test:api": "./scripts/test-api.sh",
    "build-lint": "next build && npm run lint",
    "check": "npm run build && npm run lint && npm run test"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.77.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.219.0",
    "@opentelemetry/exporter-prometheus": "0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.219.0",
    "@opentelemetry/resources": "2.8.0",
    "@opentelemetry/sdk-metrics": "2.8.0",
    "@opentelemetry/sdk-node": "0.219.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "bcrypt": "6.0.0",
    "bullmq": "5.78.1",
    "ioredis": "5.11.1",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.7.0",
    "next": "^16.2.9",
    "pino": "10.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "overrides": {
    "@grpc/grpc-js": ">=1.14.4",
    "@grpc/proto-loader": {
      "protobufjs": "^7.5.6"
    },
    "postcss": ">=8.5.10",
    "uuid": ">=14.0.0",
    "@babel/core": ">=7.29.6",
    "js-yaml": ">=4.2.0"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tsx": "4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
