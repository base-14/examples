{
  "name": "nextjs-api-mongodb",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "worker": "tsx --import ./src/jobs/instrumentation.ts src/jobs/worker.ts",
    "build:worker": "esbuild src/jobs/instrumentation.ts src/jobs/worker.ts --bundle --platform=node --target=node24 --format=esm --outdir=dist --external:bullmq --external:ioredis --external:pino --external:@opentelemetry/*",
    "test": "vitest",
    "test:api": "./scripts/test-api.sh",
    "build-lint": "next build && npm run lint"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.218.0",
    "@opentelemetry/exporter-prometheus": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "bcrypt": "6.0.0",
    "bullmq": "5.77.1",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.6.2",
    "next": "^16.2.6",
    "pino": "10.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "overrides": {
    "@grpc/proto-loader": {
      "protobufjs": "^7.5.6"
    },
    "postcss": ">=8.5.10",
    "uuid": ">=14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tsx": "4.22.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.7"
  }
}
