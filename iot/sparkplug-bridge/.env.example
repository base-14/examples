# Copy to .env, or simply `source ~/.config/base14/scout-otel-config.env`
# before `docker compose up` (the compose file reads these from the shell).
#
# Scout connection (required) — these names match scout-otel-config.env:
SCOUT_CLIENT_ID=
SCOUT_CLIENT_SECRET=
SCOUT_TOKEN_URL=
SCOUT_OTLP_ENDPOINT=

# Scout environment label applied to all telemetry (optional):
SCOUT_ENVIRONMENT=iot-demo

# Site / fleet identity for the decoder resource (optional; defaults shown):
SITE_ID=FactoryA
FLEET_ID=factory-floor

# Simulator device-restart cycle (optional; defaults shown). Lower
# DEVICE_CYCLE_S to exercise the DDEATH/DBIRTH state path sooner.
DEVICE_CYCLE_S=300

# Set to a positive integer to drop every Nth DDATA message in the
# simulator, exercising the decoder's sequence-gap detection.
DROP_EVERY_N=0
