# Copy to .env, or simply `source ~/.config/base14/scout-otel-config.env`
# before `docker compose up` (the compose file reads these from the shell).
#
# Scout connection (required) - these names match scout-otel-config.env:
SCOUT_CLIENT_ID=
SCOUT_CLIENT_SECRET=
SCOUT_TOKEN_URL=
SCOUT_OTLP_ENDPOINT=

# Scout environment label applied to all telemetry (optional):
SCOUT_ENVIRONMENT=iot-demo

# MQTT topic prefix the device publishes under and the bridge subscribes to.
# Keep the default for the local compose path. For the Wokwi public-broker
# path, set a unique prefix (e.g. scout-demo-<uuid>/mcu) on BOTH the firmware
# (via Kconfig) and the bridge, so runs do not collide on the shared broker.
TOPIC_PREFIX=scout/mcu
