# Copy to .env, or simply `source ~/.config/base14/scout-otel-config.env`
# before `docker compose up` (the compose file reads these from the shell).
#
# Scout connection (required) — these names match scout-otel-config.env:
SCOUT_CLIENT_ID=
SCOUT_CLIENT_SECRET=
SCOUT_TOKEN_URL=
SCOUT_OTLP_ENDPOINT=

# Scout environment label applied to all telemetry (optional):
SCOUT_ENVIRONMENT=iot-demo

# Site / fleet identity for the bridge resource (optional; defaults shown):
SITE_ID=site-hq
SITE_NAME=HQ Plant
FLEET_ID=factory-floor

# Simulator fault cycle (optional; defaults shown). Lower these to see a
# pump fault sooner when trying the example out.
FAULT_INTERVAL_S=600
FAULT_DURATION_S=30
