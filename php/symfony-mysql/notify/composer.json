{
    "name": "base14/symfony-notify",
    "type": "project",
    "require": {
        "php": ">=8.5",
        "open-telemetry/sdk": "^1.14",
        "open-telemetry/exporter-otlp": "^1.4",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^8.0",
        "monolog/monolog": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Notify\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
